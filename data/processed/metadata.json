    "chunks": {
        "1": {
            "chunk_id": 1,
            "chunk_section": 1,
            "section_id": 1,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "La Caja de Ahorros Banca Joven es un producto de captación que permite realizar depósitos y retiros de dinero"
        },
        "2": {
            "chunk_id": 2,
            "chunk_section": 2,
            "section_id": 1,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "y cuyos saldos devengan intereses diarios, los mismos que son capitalizados mensualmente"
        },
        "3": {
            "chunk_id": 3,
            "chunk_section": 3,
            "section_id": 1,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Dicho producto está dirigido a personas naturales del segmento joven"
        },
        "4": {
            "chunk_id": 4,
            "chunk_section": 4,
            "section_id": 1,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "de entre 18 y 35 años, de nacionalidad boliviana o extranjera con residencia legal en el país"
        },
        "5": {
            "chunk_id": 5,
            "chunk_section": 1,
            "section_id": 2,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Retiros de efectivo en plataforma de cajas o a través de cajeros automáticos mediante cualquiera de los diversos diseños de tarjetas de débito Banca Joven BNB"
        },
        "6": {
            "chunk_id": 6,
            "chunk_section": 2,
            "section_id": 2,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Posibilidad de débitos automáticos en cuenta para el pago de servicios básicos, cuotas de créditos, impuestos y otros, previa instrucción escrita del titular de la cuenta."
        },
        "7": {
            "chunk_id": 7,
            "chunk_section": 3,
            "section_id": 2,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Cuenta unipersonal."
        },
        "8": {
            "chunk_id": 8,
            "chunk_section": 4,
            "section_id": 2,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Es una cuenta para ahorro en bolivianos."
        },
        "9": {
            "chunk_id": 9,
            "chunk_section": 5,
            "section_id": 2,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Las cajas de ahorro del BNB son de convertibilidad automática, permitiendo efectuar depósitos o retiros de dinero en cualquier moneda."
        },
        "10": {
            "chunk_id": 10,
            "chunk_section": 1,
            "section_id": 3,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Personas naturales de 18 a 35 años."
        },
        "11": {
            "chunk_id": 11,
            "chunk_section": 2,
            "section_id": 3,
            "chapter_id": 1,
            "document_id": 1042,
            "text": "Cédula de identidad u otro documento a requerimiento del banco."
